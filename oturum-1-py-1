                                "impressions": {"type": "INTEGER"},
                                "ctr": {"type": "NUMBER"},
                                "position": {"type": "NUMBER"}
                            },
                            "required": ["url", "impressions", "ctr", "position"]
                        }
                    },
                    "scale_edilebilir": {
                        "type": "ARRAY",
                        "items": {
                            "type": "OBJECT",
                            "properties": {
                                "url": {"type": "STRING"},
                                "ctr": {"type": "NUMBER"},
                                "impressions": {"type": "INTEGER"}
                            },
