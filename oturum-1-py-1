def call_gemini(prompt):
    """Gemini API'yi çağırır ve yapılandırılmış JSON yanıtı alır."""

    payload = {
        "contents": [
            {
                "parts": [
                    {"text": prompt}
                ]
            }
        ],
        "generationConfig": {
            "responseMimeType": "application/json",
            "responseSchema": {
                "type": "OBJECT",
                "properties": {
                    "sge_riski": {
                        "type": "ARRAY",
