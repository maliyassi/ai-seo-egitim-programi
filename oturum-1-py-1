def parse_csv(filepath):
    """CSV dosyasını okur ve satırları dict listesi olarak döndürür."""
    rows = []
    with open(filepath, "r", encoding="utf-8-sig") as f:
        reader = csv.DictReader(f)
        for row in reader:
            try:
                url = row.get("En alakalı sayfalar", "").strip()
                clicks = int(row.get("Tıklamalar", "0").replace(".", "").replace(",", "").strip())
                impressions_raw = row.get("Gösterimler", "0").replace(".", "").replace(",", "").strip()
                impressions = int(impressions_raw)

                ctr_raw = row.get("TO", "0%").replace("%", "").replace(",", ".").strip()
                ctr = float(ctr_raw)

                pos_raw = row.get("Pozisyon", "0").replace(",", ".").strip()
                # Pozisyon "08.05" gibi olabilir, float olarak al
                position = float(pos_raw)

                rows.append({
                    "url": url,
                    "clicks": clicks,
                    "impressions": impressions,
                    "ctr": ctr,
                    "position": position
                })
            except (ValueError, TypeError) as e:
                continue
    return rows


def filter_sge_riski(data):
    """Gösterim > 10.000 VE CTR < %1 olan sayfalar"""
    return [r for r in data if r["impressions"] > 10000 and r["ctr"] < 1.0]


def filter_hizli_kazanc(data):
    """Pozisyon 4-10 arası VE gösterim > 5.000"""
    return [r for r in data if 4 <= r["position"] <= 10 and r["impressions"] > 5000]


def filter_scale_edilebilir(data):
    """CTR > %15 VE gösterim < 500"""
    return [r for r in data if r["ctr"] > 15.0 and r["impressions"] < 500]


def filter_ilk_sayfa_siniri(data):
    """Pozisyon 8-12 arası VE gösterim > 3.000"""
    return [r for r in data if 8 <= r["position"] <= 12 and r["impressions"] > 3000]


def find_duplicate_url_suspects(data):
    """
    Benzer URL pattern'ları bulur:
    - trailing slash farkı (örn: /abc vs /abc/)
    - aynı slug farklı path
    """
    duplicates = []
    url_map = {}

    for row in data:
        url = row["url"].rstrip("/")
        if url in url_map:
            url_map[url].append(row)
        else:
            url_map[url] = [row]

    # Trailing slash farkı olan URL'leri bul
    seen_pairs = set()
    for row in data:
        url = row["url"]
        normalized = url.rstrip("/")

        # trailing slash varyantını kontrol et
        if url.endswith("/"):
            counterpart = url[:-1]
        else:
            counterpart = url + "/"

        # Counterpart'ı veri setinde ara
        for other_row in data:
            if other_row["url"] == counterpart:
                pair_key = tuple(sorted([url, counterpart]))
                if pair_key not in seen_pairs:
                    seen_pairs.add(pair_key)
                    duplicates.append({
                        "url_1": url,
                        "url_2": counterpart,
                        "impressions_1": row["impressions"],
                        "impressions_2": other_row["impressions"]
                    })

    return duplicates


