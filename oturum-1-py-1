                            "properties": {
                                "url": {"type": "STRING"},
                                "position": {"type": "NUMBER"},
                                "impressions": {"type": "INTEGER"}
                            },
                            "required": ["url", "position", "impressions"]
                        }
                    },
                    "duplicate_url_suphe": {
                        "type": "ARRAY",
                        "items": {
                            "type": "OBJECT",
                            "properties": {
                                "url_1": {"type": "STRING"},
                                "url_2": {"type": "STRING"},
                                "impressions_1": {"type": "INTEGER"},
                                "impressions_2": {"type": "INTEGER"}
                            },
                            "required": ["url_1", "url_2", "impressions_1", "impressions_2"]
                        }
                    },
                    "grup_ozeti": {
                        "type": "OBJECT",
                        "properties": {
                            "sge_riski_toplam": {"type": "INTEGER"},
                            "sge_riski_aksiyon": {"type": "STRING"},
                            "hizli_kazanc_toplam": {"type": "INTEGER"},
                            "hizli_kazanc_aksiyon": {"type": "STRING"},
                            "scale_edilebilir_toplam": {"type": "INTEGER"},
                            "scale_edilebilir_aksiyon": {"type": "STRING"},
                            "ilk_sayfa_siniri_toplam": {"type": "INTEGER"},
                            "ilk_sayfa_siniri_aksiyon": {"type": "STRING"},
                            "duplicate_url_suphe_toplam": {"type": "INTEGER"},
                            "duplicate_url_suphe_aksiyon": {"type": "STRING"}
                        },
                        "required": [
                            "sge_riski_toplam", "sge_riski_aksiyon",
                            "hizli_kazanc_toplam", "hizli_kazanc_aksiyon",
                            "scale_edilebilir_toplam", "scale_edilebilir_aksiyon",
